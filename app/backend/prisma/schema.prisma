datasource db {
  provider = "postgresql"
}



generator client {
  provider = "prisma-client-js"
}

// ─── USUARIOS ───

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(CUSTOMER)
  googleId  String?  @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}


model Address {
  id        Int     @id @default(autoincrement())
  userId    Int
  street    String
  city      String
  reference String?
  isDefault Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

// ─── CATÁLOGO ───

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  categoryId  Int
  productType String
  hasSizes    Boolean  @default(false)
  basePrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category          @relation(fields: [categoryId], references: [id])
  sizes      ProductSize[]
  modifiers  ProductModifier[]
  orderItems OrderItem[]
}

model ProductSize {
  id        Int     @id @default(autoincrement())
  productId Int
  size      Size
  price     Decimal @db.Decimal(10, 2)

  product    Product     @relation(fields: [productId], references: [id])
  orderItems OrderItem[]

  @@unique([productId, size])
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}

model ProductModifier {
  id         Int     @id @default(autoincrement())
  productId  Int
  name       String
  extraPrice Decimal @db.Decimal(10, 2) @default(0)

  product       Product             @relation(fields: [productId], references: [id])
  orderItemMods OrderItemModifier[]
}

// ─── PEDIDOS ───

model Order {
  id           Int          @id @default(autoincrement())
  userId       Int
  addressId    Int?
  deliveryType DeliveryType
  status       OrderStatus  @default(PENDING)
  subtotal     Decimal      @db.Decimal(10, 2)
  deliveryFee  Decimal      @db.Decimal(10, 2) @default(0)
  total        Decimal      @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User       @relation(fields: [userId], references: [id])
  address Address?   @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  payment Payment?
}

enum DeliveryType {
  DELIVERY
  LOCAL
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  DELIVERED
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  orderId       Int
  productId     Int
  productSizeId Int?
  quantity      Int
  unitPrice     Decimal @db.Decimal(10, 2)
  totalPrice    Decimal @db.Decimal(10, 2)

  order       Order              @relation(fields: [orderId], references: [id])
  product     Product            @relation(fields: [productId], references: [id])
  productSize ProductSize?       @relation(fields: [productSizeId], references: [id])
  modifiers   OrderItemModifier[]
}

model OrderItemModifier {
  id          Int     @id @default(autoincrement())
  orderItemId Int
  modifierId  Int
  extraPrice  Decimal @db.Decimal(10, 2)

  orderItem OrderItem       @relation(fields: [orderItemId], references: [id])
  modifier  ProductModifier @relation(fields: [modifierId], references: [id])
}

// ─── PAGOS ───

model Payment {
  id             Int           @id @default(autoincrement())
  orderId        Int           @unique
  mpPaymentId    String?       @unique
  mpPreferenceId String?
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}
